menu "Air Monitor"

config AIRMON_I2C_PORT_NUM
    int "SCD41 I2C port"
    range 0 1
    default 0

config AIRMON_I2C_SDA_GPIO
    int "SCD41 SDA GPIO"
    default 8

config AIRMON_I2C_SCL_GPIO
    int "SCD41 SCL GPIO"
    default 9

config AIRMON_UART_PORT_NUM
    int "PMS7003 UART port"
    range 0 2
    default 1

config AIRMON_PMS_RX_GPIO
    int "PMS7003 RX GPIO"
    default 18

config AIRMON_PMS_TX_GPIO
    int "PMS7003 TX GPIO"
    default 17

config AIRMON_PMS_SET_GPIO
    int "PMS7003 SET GPIO"
    default 16

config AIRMON_PMS_RST_GPIO
    int "PMS7003 RESET GPIO"
    default 15

config AIRMON_PUBLISH_INTERVAL_DEFAULT
    int "Default publish interval (seconds)"
    range 5 60
    default 10

config AIRMON_WIFI_MAX_RETRY
    int "Wi-Fi retry attempts before AP fallback"
    range 3 120
    default 20

config AIRMON_WIFI_CONNECT_TIMEOUT_MS
    int "Wi-Fi connect timeout (ms)"
    range 3000 120000
    default 30000

config AIRMON_AP_FALLBACK_TIMEOUT_SEC
    int "Runtime offline timeout before AP fallback"
    range 30 900
    default 180

config AIRMON_AP_SSID_PREFIX
    string "SoftAP SSID prefix"
    default "airmon"

endmenu
